<mujoco model="omni_ballbot">
  <compiler angle="radian" meshdir="../meshes/"/>
  <!--cone决定了打滑时摩擦力的极限边界为椭圆形  impratio为接触阻抗比-->
  <option cone="elliptic" impratio="10"/>
<!--资产meshes-->
  <asset>
    <mesh name="base_link" file="base_link.STL"/>
    <mesh name="wheel_base" file="wheel_base.STL"/>
    <mesh name="wheel_link_A" file="wheel_link_A.STL"/>
    <mesh name="wheel_link_B" file="wheel_link_B.STL"/>
  </asset>
<!--执行器actuator-->
  <actuator>
    <motor name="wheel1" joint="wheel1_joint" ctrlrange="-2.5 2.5" gear="1"/>
    <motor name="wheel2" joint="wheel2_joint" ctrlrange="-2.5 2.5" gear="1"/>
    <motor name="wheel3" joint="wheel3_joint" ctrlrange="-2.5 2.5" gear="1"/>
  </actuator>
<!--辊子组别-->
  <!-- 物体A 和 物体B 发生碰撞的条件是：(注：& 是二进制按位与运算) 
      A_contype & B_conaffinity > 0 就碰撞 或者 B_contype & A_conaffinity > 0
  -->
  <!-- 默认地面是 contype="1", conaffinity="1" -->
  <default>
    <default class="omni_roller">
      <!--type="mesh": 告诉引擎别用简单的球或圆柱，去读取你的 STL 文件算凸包，还原最真实的鼓形外轮廓-->
      <!--接触维度:3维算垂直弹力 + 沿面滑动的摩擦力；-->
      <!-- 0.8 (滑动摩擦): 沿着接触面切线的滑动阻力。0.8 是典型的软橡胶对金属/硬塑料的摩擦系数，提供极强的抓地力，让你的轮子能驱动球。
           0.05 (扭转摩擦): 绕着接触法线原地扭转的阻力。设小一点，是因为小辊子在球面上往往伴随着微小的原地自转滑动，太大容易卡死。
           0.0001 (滚动摩擦): 抵抗向前滚动的力。极其微小，模拟轴承的极致丝滑。 -->
      <!-- margin="0.001" (碰撞裕度): * 网格模型表面会有微小的“棱角”。这个参数会在你的 3D 模型外面“包”一层 1 毫米厚的隐形软垫。
        它能让引擎提前介入计算，把网格相撞时的尖锐脉冲力“柔化”，控制器读取到的力矩曲线会非常平滑。 -->
      <geom type="mesh" contype="2" conaffinity="1" condim="3" friction="0.8 0.05 0.0001" margin="0.001" solref="0.01 1" solimp="0.9 0.95 0.001 0.5 2"/>
      
      <!-- type="hinge": 所有的辊子只能绕自己的那根轴转。
           damping="0.001" (粘性阻尼): * 含义： 阻力与转速成正比（转得越快阻力越大）。模拟轴承里润滑油的粘滞力
           frictionloss="0.001" (干摩擦/静摩擦损失):启动阻力。你必须施加大于这个值的扭矩，辊子才会开始转。模拟金属部件之间的静摩擦。 -->
      <joint type="hinge" damping="0.001" frictionloss="0.001" armature="0.0001"/>
    </default>
    
    <default class="visual_geom">
      <geom type="mesh" contype="0" conaffinity="0" group="1" density="0"/>
    </default>
  </default>
