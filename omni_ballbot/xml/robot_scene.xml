<mujoco model="mjmodel scene">

  <!--引用机器人模型-->
  <include file="omni_ballbot.xml"/>
  <!--设置场景统计信息显示范围 中心位于(0,0,0.1)，半径 0.8 米-->
  <statistic center="0 0 0.1" extent="0.8"/>

  <!--视觉全局设置-->
  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="-130" elevation="-20"/>
  </visual>
  <!--天空盒纹理 地面纹理-->
  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
    <mesh name="roll_arrow_ring" file="roll_arrow_ring.stl"/>
  </asset>
  <!---->
  <!--地面平面和球-->
  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/> 
    <!--地面摩擦力在这-->
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane" friction="1.0 0.003 0.0005"/>
  <!--球-->
    <body name="balance_ball" pos="0 0 0.15">
      <freejoint name="ball_joint"/>
      <geom name="ball_geom" type="sphere" size="0.15" mass="0.6" rgba="0.8 0.4 0.2 1"
            condim="6" friction="1.0 0.003 0.0005"
            solref="0.02 1" solimp="0.9 0.95 0.001 0.5 2" margin="0.002"/>
      <!-- 球滚动方向可视化：两个正交圆环，随球旋转 -->
      <geom type="mesh" mesh="roll_arrow_ring" rgba="0 1 0 0.85" contype="0" conaffinity="0"/>
      <geom type="mesh" mesh="roll_arrow_ring" rgba="1 0 0 0.85" contype="0" conaffinity="0" quat="0.707 0 0 0.707"/>
    </body>
  </worldbody>
</mujoco>
